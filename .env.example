# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/reelforge?schema=public"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="reelforge"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
ENCRYPTION_KEY="replace-with-a-64-char-hex-key"

# OAuth integrations
GITHUB_ID="your-github-oauth-app-client-id"
GITHUB_SECRET="your-github-oauth-app-client-secret"
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
DROPBOX_APP_KEY="your-dropbox-app-key"
DROPBOX_APP_SECRET="your-dropbox-app-secret"

# Cloudflare R2 (planned; current production slice still stores uploads/renders on local disk)
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="your-r2-bucket"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com/<bucket>"
R2_PUBLIC_URL="https://cdn.example.com"

# OpenAI (optional; user may provide their own key in-product)
OPENAI_API_KEY=""
NEXT_PUBLIC_OPENAI_API_KEY=""

# Render/runtime tools
FFMPEG_PATH="ffmpeg"
FFPROBE_PATH="ffprobe"

# Persistent local storage (required for current local-disk asset + render flow)
UPLOAD_DIR="./public/uploads"
RENDER_DIR="./public/renders"
SHADER_DIR="./public/shaders"

# Queue / Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"
